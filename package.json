{
  "name": "hometown-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Hometown Hub — Digital Community Platform",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "next dev --turbopack -p 3000",
    "dev:server": "cd server && npm run dev",
    "build": "next build && cd server && npm run build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.62.0",
    "@types/leaflet": "^1.9.21",
    "@types/three": "^0.184.1",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "cobe": "^2.0.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^11.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.18.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.4.0",
    "react-intersection-observer": "^10.0.3",
    "react-leaflet": "^5.0.0",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^2.6.0",
    "three": "^0.184.0",
    "use-debounce": "^10.1.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  }
}
